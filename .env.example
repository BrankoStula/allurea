# Allurea — required environment variables
# Copy to .env locally and fill values.
# On Vercel, declare these under Project Settings -> Environment Variables.

# Mapbox GL JS token (used in components/ui/MapboxMap.tsx via NEXT_PUBLIC_*)
# Get from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Apps Script web app URL (inquiry form submission target)
# Create new Apps Script + deploy as web app, paste /exec URL here
# NEXT_PUBLIC_ prefix required because InquiryForm is a client component
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=
